# Vast.ai environment — copy to .env on the remote instance before training.
# On Vast.ai, Google Drive is NOT mounted locally; use rclone to sync data first.

# Local workspace path on the Vast.ai instance
DATA_ROOT=/workspace/fake-news-data-for-thesis

# Not needed on Vast.ai (Drive access is handled by rclone, not the Python API)
# GOOGLE_APPLICATION_CREDENTIALS=
