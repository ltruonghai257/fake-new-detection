# Windows local machine environment — copy to .env and update USERNAME.
# Google Drive Desktop app mounts at a local path.

# Local path on Windows (Google Drive Desktop app)
# Use forward slashes OR raw strings in Python: r"C:\Users\[USERNAME]\..."
DATA_ROOT=C:/Users/[USERNAME]/Google Drive/My Drive/Thesis_Final/fake-news-data-for-thesis

# Platform identifier (used by env_utils.py)
PLATFORM=windows

# Not needed for local Windows (Drive is mounted locally)
# GOOGLE_APPLICATION_CREDENTIALS=
