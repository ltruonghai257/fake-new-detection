# macOS local machine environment — copy to .env and update USERNAME/EMAIL.
# Google Drive Desktop app mounts at ~/Library/CloudStorage/

# Local path on macOS (Google Drive Desktop app)
# Note: The CloudStorage path format varies by Google account email.
# Check your exact path with: ls ~/Library/CloudStorage/
DATA_ROOT=/Users/[USERNAME]/Library/CloudStorage/GoogleDrive-[EMAIL]/My Drive/Thesis_Final/fake-news-data-for-thesis

# Platform identifier (used by env_utils.py)
PLATFORM=mac

# Not needed for local Mac (Drive is mounted locally)
# GOOGLE_APPLICATION_CREDENTIALS=
