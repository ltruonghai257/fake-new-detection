<mxfile host="app.diagrams.net">
  <diagram id="anchored-coolant-arch" name="AnchoredCOOLANT Architecture">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- TITLE -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="title" value="AnchoredCOOLANT — Model Architecture" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="800" height="30" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- INPUTS ROW -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="inp-caption" value="Caption Embeddings
[B, 768, seq_len]
(PhoBERT tokens)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="inp-image" value="ResNet50 Features
[B, 2048]" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="80" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="inp-anchor" value="Stage 03.9 PhoBERT CLS
[B, 768]
(frozen — Direction 1)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1130" y="80" width="190" height="60" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SIMILARITY MODULE BOX -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="sim-box" value="SimilarityModule" style="swimlane;fillColor=#f5f5f5;strokeColor=#666;fontStyle=1;fontSize=12;startSize=24;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="420" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sim-enc" value="EncodingPart
FastCNN(text) + Linear(image)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sim-box">
          <mxGeometry x="20" y="35" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sim-out" value="text_aligned_sim [B,64]
image_aligned_sim [B,64]
similarity_pred [B,2]" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="sim-box">
          <mxGeometry x="220" y="35" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sim-enc-out-e" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sim-enc" target="sim-out" parent="sim-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sim-loss" value="Cosine Loss" style="ellipse;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="sim-box">
          <mxGeometry x="100" y="88" width="90" height="28" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CLIP MODULE BOX -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="clip-box" value="CLIPModule" style="swimlane;fillColor=#f5f5f5;strokeColor=#666;fontStyle=1;fontSize=12;startSize=24;" vertex="1" parent="1">
          <mxGeometry x="530" y="210" width="360" height="120" as="geometry" />
        </mxCell>
        <mxCell id="clip-proj" value="ImageProjection [2048→64]
TextProjection [768→64]" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="clip-box">
          <mxGeometry x="20" y="35" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="clip-out" value="image_aligned_clip [B,64]
text_aligned_clip [B,64]" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="clip-box">
          <mxGeometry x="210" y="35" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="clip-proj-out-e" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="clip-proj" target="clip-out" parent="clip-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="clip-loss" value="CLIP + Soft CE Loss" style="ellipse;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="clip-box">
          <mxGeometry x="90" y="88" width="120" height="28" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- ANCHORED DETECTION MODULE — big swimlane -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="det-box" value="AnchoredDetectionModule (Direction 1)" style="swimlane;fillColor=#f0f0ff;strokeColor=#5050aa;fontStyle=1;fontSize=12;startSize=24;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="1260" height="360" as="geometry" />
        </mxCell>

        <!-- encoding -->
        <mxCell id="det-enc" value="EncodingPart
FastCNN(text)
Linear(image)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="det-box">
          <mxGeometry x="20" y="45" width="130" height="65" as="geometry" />
        </mxCell>

        <!-- uni_se + uni_repre -->
        <mxCell id="det-unise" value="UniSE
SE-attention
text/image" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="det-box">
          <mxGeometry x="185" y="45" width="110" height="65" as="geometry" />
        </mxCell>

        <!-- cross module -->
        <mxCell id="det-cross" value="CrossModule4Batch
cross-modal correlation
[B, 32]" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="det-box">
          <mxGeometry x="330" y="45" width="140" height="65" as="geometry" />
        </mxCell>

        <!-- senet attention -->
        <mxCell id="det-se" value="SENet
attention_score [B,3]
(text / image / corre)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="det-box">
          <mxGeometry x="505" y="45" width="140" height="65" as="geometry" />
        </mxCell>

        <!-- weighted combine -->
        <mxCell id="det-combine" value="Weighted Combine
text_final [B,32]
img_final [B,32]
corre_final [B,32]" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="det-box">
          <mxGeometry x="678" y="35" width="130" height="80" as="geometry" />
        </mxCell>

        <!-- concat final_corre -->
        <mxCell id="det-concat1" value="Concat
final_corre [B,96]" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="det-box">
          <mxGeometry x="678" y="155" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- anchor proj -->
        <mxCell id="det-anchor-proj" value="anchor_proj
Linear(768→64)
+ BN + ReLU
anchor [B,64]" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="det-box">
          <mxGeometry x="840" y="140" width="130" height="75" as="geometry" />
        </mxCell>

        <!-- concat anchor -->
        <mxCell id="det-concat2" value="Concat [B,160]
final_corre ++ anchor" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;" vertex="1" parent="det-box">
          <mxGeometry x="1005" y="155" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- classifier -->
        <mxCell id="det-clf" value="classifier_corre
Linear(160→64)→ReLU
→Linear(64→2)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="det-box">
          <mxGeometry x="1005" y="250" width="140" height="65" as="geometry" />
        </mxCell>

        <!-- ambiguity module -->
        <mxCell id="det-amb" value="AmbiguityLearning
skl scalar [B]" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="det-box">
          <mxGeometry x="185" y="230" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- skl_score -->
        <mxCell id="det-skl" value="ambiguity_weights [B,3]
[1-skl, 1-skl, skl]" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="det-box">
          <mxGeometry x="350" y="230" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- NEI loss box -->
        <mxCell id="det-nei" value="NEI-Ambiguity Loss (Dir 2)
mean(P(NEI) × (1−skl))" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="det-box">
          <mxGeometry x="350" y="305" width="175" height="45" as="geometry" />
        </mxCell>

        <!-- detection loss -->
        <mxCell id="det-loss" value="Detection Loss
CE + KL_div + λ·NEI" style="ellipse;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="det-box">
          <mxGeometry x="870" y="305" width="155" height="45" as="geometry" />
        </mxCell>

        <!-- ═══ INTERNAL EDGES in det-box ═══ -->
        <mxCell id="e-enc-unise" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-enc" target="det-unise" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-enc-cross" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-enc" target="det-cross" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-unise-se" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-unise" target="det-se" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-cross-se" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-cross" target="det-se" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-se-combine" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-se" target="det-combine" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-combine-concat1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-combine" target="det-concat1" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-concat1-concat2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-concat1" target="det-concat2" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-anchorproj-concat2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;" edge="1" source="det-anchor-proj" target="det-concat2" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-concat2-clf" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-concat2" target="det-clf" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-enc-amb" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=1;entryX=0;entryY=0;" edge="1" source="det-enc" target="det-amb" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-amb-skl" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-amb" target="det-skl" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-skl-nei" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-skl" target="det-nei" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-skl-detloss" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-skl" target="det-loss" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-clf-detloss" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-clf" target="det-loss" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-nei-detloss" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;" edge="1" source="det-nei" target="det-loss" parent="det-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- OUTPUT -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="out-logits" value="detection_logits [B,2]
Real / Fake" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="800" width="170" height="55" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- CROSS-BOX EDGES -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- caption → sim -->
        <mxCell id="e-cap-sim" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="inp-caption" target="sim-box" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- image → sim -->
        <mxCell id="e-img-sim" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="inp-image" target="sim-box" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- caption → clip -->
        <mxCell id="e-cap-clip" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="inp-caption" target="clip-box" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- image → clip -->
        <mxCell id="e-img-clip" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="inp-image" target="clip-box" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- caption → det-box (enters det-enc) -->
        <mxCell id="e-cap-det" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="inp-caption" target="det-enc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- image → det-box (enters det-enc) -->
        <mxCell id="e-img-det" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="inp-image" target="det-enc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- clip out → det cross (text/image aligned clip feeds cross module) -->
        <mxCell id="e-clip-det-cross" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;" edge="1" source="clip-box" target="det-cross" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- anchor → det-anchor-proj -->
        <mxCell id="e-anchor-proj" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;" edge="1" source="inp-anchor" target="det-anchor-proj" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- det-clf → output logits -->
        <mxCell id="e-clf-out" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="det-clf" target="out-logits" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- LEGEND -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="legend" value="Legend" style="swimlane;fillColor=#f5f5f5;strokeColor=#999;fontSize=11;fontStyle=1;startSize=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="800" width="380" height="75" as="geometry" />
        </mxCell>
        <mxCell id="leg1" value="Input tensor" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="legend">
          <mxGeometry x="10" y="25" width="80" height="30" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="Frozen anchor (Dir 1)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="legend">
          <mxGeometry x="100" y="25" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="Concat [B,160]" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="legend">
          <mxGeometry x="230" y="25" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="Loss term" style="ellipse;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="legend">
          <mxGeometry x="340" y="25" width="30" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
<diagram id="5mpbjsdh-b2b8" name="COOLANT vs AnchoredCOOLANT"><mxGraphModel dx="1600" dy="1000" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- TITLE -->
    <mxCell id="title" value="COOLANT vs AnchoredCOOLANT — Architectural Comparison" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="300" y="15" width="1000" height="30" as="geometry" />
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- LEFT: COOLANT (baseline) -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <mxCell id="left-header" value="COOLANT (Stage 03 — Baseline)" style="text;html=1;fontSize=14;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666;align=center;" vertex="1" parent="1">
      <mxGeometry x="40" y="55" width="680" height="30" as="geometry" />
    </mxCell>

    <!-- Inputs -->
    <mxCell id="l-cap" value="Caption [B,768,seq]" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="105" width="160" height="40" as="geometry" />
    </mxCell>
    <mxCell id="l-img" value="Image [B,2048]" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="480" y="105" width="160" height="40" as="geometry" />
    </mxCell>

    <!-- Task1 -->
    <mxCell id="l-sim" value="SimilarityModule" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="185" width="160" height="45" as="geometry" />
    </mxCell>
    <mxCell id="l-clip" value="CLIPModule" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="480" y="185" width="160" height="45" as="geometry" />
    </mxCell>

    <!-- DetectionModule -->
    <mxCell id="l-det-box" value="DetectionModule (original)" style="swimlane;fillColor=#f5f5f5;strokeColor=#666;fontStyle=1;fontSize=11;startSize=24;" vertex="1" parent="1">
      <mxGeometry x="40" y="275" width="680" height="230" as="geometry" />
    </mxCell>
    <mxCell id="l-enc" value="EncodingPart" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="l-det-box">
      <mxGeometry x="20" y="40" width="110" height="45" as="geometry" />
    </mxCell>
    <mxCell id="l-cross" value="CrossModule4Batch" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="l-det-box">
      <mxGeometry x="160" y="40" width="130" height="45" as="geometry" />
    </mxCell>
    <mxCell id="l-se" value="SENet attention [B,3]" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="l-det-box">
      <mxGeometry x="320" y="40" width="130" height="45" as="geometry" />
    </mxCell>
    <mxCell id="l-combine" value="Weighted combine
final_corre [B,96]" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="l-det-box">
      <mxGeometry x="480" y="40" width="150" height="45" as="geometry" />
    </mxCell>
    <mxCell id="l-clf" value="classifier_corre
Linear(96→64)→ReLU
→Linear(64→2)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="l-det-box">
      <mxGeometry x="480" y="130" width="150" height="65" as="geometry" />
    </mxCell>
    <mxCell id="l-amb" value="AmbiguityLearning
skl [B]" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="l-det-box">
      <mxGeometry x="160" y="140" width="130" height="45" as="geometry" />
    </mxCell>
    <mxCell id="le1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="l-enc" target="l-cross" parent="l-det-box"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="le2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="l-cross" target="l-se" parent="l-det-box"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="le3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="l-se" target="l-combine" parent="l-det-box"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="le4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="l-combine" target="l-clf" parent="l-det-box"><mxGeometry relative="1" as="geometry" /></mxCell>
    <mxCell id="le5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="l-enc" target="l-amb" parent="l-det-box"><mxGeometry relative="1" as="geometry" /></mxCell>

    <!-- Output -->
    <mxCell id="l-out" value="detection_logits [B,2]" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="460" y="545" width="180" height="40" as="geometry" />
    </mxCell>

    <!-- Losses -->
    <mxCell id="l-loss1" value="Cosine Loss (similarity)" style="ellipse;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="60" y="555" width="160" height="35" as="geometry" />
    </mxCell>
    <mxCell id="l-loss2" value="CLIP + CE Loss" style="ellipse;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="240" y="555" width="140" height="35" as="geometry" />
    </mxCell>
    <mxCell id="l-loss3" value="CE + KL_div (detection)" style="ellipse;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="460" y="600" width="160" height="35" as="geometry" />
    </mxCell>

