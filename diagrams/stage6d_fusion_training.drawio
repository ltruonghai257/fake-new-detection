        <mxCell id="13" value="h_img [B,32,256]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="5" source="8" target="9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="14" value="ctx [B,256]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="5" source="9" target="10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="15" value="h_t [B,256]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="5" source="7" target="10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Loss -->
        <mxCell id="16" value="&lt;b&gt;Cross-Entropy Loss&lt;/b&gt;&#xa;3-class: Real / Fake / NEI"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="380" y="730" width="340" height="85" as="geometry" />
        </mxCell>

        <!-- Differential LR optimizer -->
        <mxCell id="17" value="&lt;b&gt;Differential-LR AdamW&lt;/b&gt;  +  LR Scheduler&#xa;PhoBERT unfrozen layers: lr = 1e-5&#xa;Fusion head (projectors + cross-attn + MLP): lr = 3e-4"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="875" width="700" height="75" as="geometry" />
