<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Stage 6d: End-to-End Fusion">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="Stage 6d: End-to-End Fine-Tuning — PhoBERT + COOLANT Cross-Attention Fusion"
          style="text;html=1;align=center;fontStyle=1;fontSize=15;fillColor=none;strokeColor=none;"
          vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="1000" height="40" as="geometry" />
        </mxCell>

        <!-- Input: stage06d cache -->
        <mxCell id="3" value="&lt;b&gt;stage06d_cache / {split}.h5&lt;/b&gt;&#xa;statements (claim text)  |  contexts (article)  |  evidences&#xa;image_features [N, 32, 64]  |  pair_counts  |  labels (Real/Fake/NEI)"
          style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="225" y="80" width="650" height="80" as="geometry" />
        </mxCell>

        <!-- Dataset / tokenization -->
        <mxCell id="4" value="&lt;b&gt;FinetuneFusionDataset&lt;/b&gt;&#xa;Online tokenization: tokenizer(statement, context, truncation=True, padding=max_length)&#xa;Returns: input_ids [B, seq], attention_mask, image_feat [B, 32, 64], pair_counts, label"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="150" y="220" width="800" height="70" as="geometry" />
        </mxCell>

        <!-- FinetuneFusionModel container -->
        <mxCell id="5" value="FinetuneFusionModel"
          style="swimlane;startSize=35;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="350" width="980" height="320" as="geometry" />
        </mxCell>

        <!-- PhoBERT encoder -->
        <mxCell id="6" value="&lt;b&gt;PhoBERT Encoder&lt;/b&gt;&#xa;vinai/phobert-base-v2&#xa;unfreeze_last_n=3 layers&#xa;CLS token → [B, 768]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="5">
          <mxGeometry x="20" y="50" width="210" height="95" as="geometry" />
        </mxCell>

        <!-- text_proj -->
        <mxCell id="7" value="&lt;b&gt;text_proj&lt;/b&gt;&#xa;Linear(768 → proj_dim)&#xa;LayerNorm + ReLU&#xa;→ h_t [B, 256]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="5">
          <mxGeometry x="260" y="50" width="190" height="95" as="geometry" />
        </mxCell>

        <!-- image_proj -->
        <mxCell id="8" value="&lt;b&gt;image_proj&lt;/b&gt;&#xa;Linear(64 → proj_dim)&#xa;LayerNorm + ReLU&#xa;→ h_img [B, 32, 256]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="5">
          <mxGeometry x="480" y="50" width="190" height="95" as="geometry" />
        </mxCell>

        <!-- Stacked Cross-Attention -->
        <mxCell id="9" value="&lt;b&gt;StackedCrossAttention&lt;/b&gt;  (num_attn_layers=2)&#xa;Query = h_t [B, 1, 256]&#xa;Key / Value = h_img [B, 32, 256]&#xa;Key-padding mask (pair_counts)&#xa;→ ctx [B, 256]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9673a6;strokeColor=#6a5481;fontColor=#ffffff;fontSize=11;"
          vertex="1" parent="5">
          <mxGeometry x="260" y="185" width="410" height="105" as="geometry" />
        </mxCell>

        <!-- MLP Classifier -->
        <mxCell id="10" value="&lt;b&gt;MLP Classifier&lt;/b&gt;&#xa;cat([h_t, ctx]) → [B, 512]&#xa;Linear(512→256) → ReLU&#xa;Linear(256→128) → ReLU&#xa;Linear(128 → num_classes=3)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="5">
          <mxGeometry x="730" y="95" width="230" height="155" as="geometry" />
        </mxCell>

        <!-- Internal edges -->
        <mxCell id="11" value="[B, 768]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;" edge="1" parent="5" source="6" target="7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="12" value="h_t [B,256]" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="5" source="7" target="9">
