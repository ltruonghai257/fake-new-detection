    <!-- ══ TRAINABLE HEAD section header ══ -->
    <mxCell id="trainbg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF5FF;strokeColor=#7C3AED;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="80" y="396" width="1000" height="26" as="geometry"/>
    </mxCell>
    <mxCell id="trainlbl" value="TRAINABLE FUSION HEAD  —  MILAttentionFusionHead  (~200K params, only these are updated)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=9;fontStyle=1;fontColor=#6D28D9;" vertex="1" parent="1">
      <mxGeometry x="80" y="396" width="1000" height="26" as="geometry"/>
    </mxCell>

    <!-- TextProjector -->
    <mxCell id="txtproj" value="TextProjector&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;Linear(768 → 256)&#xa;LayerNorm(256)&#xa;ReLU()&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;→ h_t  [B, 256]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;fontSize=8.5;align=left;" vertex="1" parent="1">
      <mxGeometry x="100" y="432" width="180" height="120" as="geometry"/>
    </mxCell>

    <!-- ImageProjector -->
    <mxCell id="imgproj" value="ImageProjector&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;(applied to each pair)&#xa;reshape [B,P,64]→[B*P,64]&#xa;Linear(64 → 256)&#xa;LayerNorm(256)&#xa;ReLU()&#xa;reshape → [B, P, 256]&#xa;━━━━━━━━━━━━━━━━━━━━&#xa;→ h_img  [B, 8, 256]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;fontSize=8.5;align=left;" vertex="1" parent="1">
      <mxGeometry x="100" y="570" width="180" height="148" as="geometry"/>
    </mxCell>

    <!-- MILAttentionPooling -->
    <mxCell id="milattn" value="MILAttentionPooling  (Luong tanh-dot)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;W: Linear(256 → 256, no bias)&#xa;v: Linear(256 → 1,   no bias)&#xa;─────────────────────────────────────────────────────&#xa;scores_i = v · tanh(W · h_img_i)     [B, P]&#xa;mask:  True where i ≥ pair_count   (padding positions)&#xa;scores = masked_fill(mask, −∞)&#xa;α = softmax(scores, dim=−1)          [B, 8]&#xa;α = masked_fill(isnan(α), 0.0)       (edge case: all-pad)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;h_img_agg = Σᵢ αᵢ · h_img_i          [B, 256]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDD6FE;strokeColor=#7C3AED;strokeWidth=2;fontSize=8.5;align=left;" vertex="1" parent="1">
      <mxGeometry x="330" y="532" width="470" height="196" as="geometry"/>
    </mxCell>

    <!-- Concat -->
    <mxCell id="catnode" value="concat([h_t, h_img_agg], dim=−1)&#xa;[B, 256+256] = [B, 512]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C4B5FD;strokeColor=#7C3AED;strokeWidth=2;fontSize=9;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="330" y="432" width="330" height="50" as="geometry"/>
    </mxCell>

    <!-- AsymmetricGate -->
    <mxCell id="gate" value="AsymmetricGate&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;gate: Linear(512 → 256)&#xa;g = sigmoid(gate([h_t; h_img_agg]))    [B, 256]&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;fused = g ⊙ h_t  +  (1 − g) ⊙ h_img_agg&#xa;→ fused  [B, 256]&#xa;(g &gt; 0.5 → text-dominant; asymmetric by input richness)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A78BFA;strokeColor=#7C3AED;strokeWidth=2;fontSize=8.5;align=left;" vertex="1" parent="1">
      <mxGeometry x="330" y="746" width="470" height="128" as="geometry"/>
    </mxCell>

    <!-- Classifier -->
    <mxCell id="clf" value="Classifier&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Dropout(p=0.3)&#xa;Linear(256 → 3)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;→ logits  [B, 3]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#4C1D95;strokeWidth=2;fontSize=8.5;align=left;fontColor=#FFFFFF;" vertex="1" parent="1">
      <mxGeometry x="330" y="892" width="470" height="90" as="geometry"/>
    </mxCell>

    <!-- Output -->
    <mxCell id="outnode" value="Output  [B, 3]&#xa;argmax → ŷ ∈ {0, 1, 2}&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;0 = Real (Supported)&#xa;1 = Fake (Refuted)&#xa;2 = NEI  (Not Enough Info)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4C1D95;strokeColor=#2E1065;strokeWidth=2;fontSize=9;fontStyle=1;fontColor=#FFFFFF;" vertex="1" parent="1">
      <mxGeometry x="330" y="1000" width="470" height="80" as="geometry"/>
    </mxCell>

    <!-- LOSS box -->
    <mxCell id="lossbox" value="Loss: WeightedCrossEntropyLoss&#xa;+ label_smoothing=0.1&#xa;class_weights: len(train)/(3·counts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#DC2626;strokeWidth=1.5;fontSize=8.5;" vertex="1" parent="1">
      <mxGeometry x="840" y="892" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="optbox" value="Optimizer: AdamW&#xa;lr=3e-4, wd=1e-4&#xa;Scheduler: OneCycleLR&#xa;batch=32 articles&#xa;patience=8 (val macro-F1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF2F2;strokeColor=#DC2626;strokeWidth=1.5;fontSize=8.5;" vertex="1" parent="1">
      <mxGeometry x="840" y="966" width="220" height="72" as="geometry"/>
    </mxCell>

    <!-- Attn weights side output -->
    <mxCell id="attnout" value="attn_weights  [B, 8]&#xa;(returned for inspection)&#xa;shows which pair matters most" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;strokeWidth=1;dashed=1;fontSize=8;" vertex="1" parent="1">
      <mxGeometry x="840" y="614" width="200" height="52" as="geometry"/>
