    <mxCell id="residblock" value="residual_norm: LayerNorm(256)   (on h_t before adding)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;output = fused  +  residual_norm(h_t)               [B, 256]&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;Rationale: preserves PhoBERT NEI signal even if gate overwhelms text path.&#xa;LayerNorm stabilises residual scale vs. gated output." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=8.5;fontColor=#9A3412;" vertex="1" parent="1">
