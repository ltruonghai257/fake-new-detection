    </mxCell>

    <!-- Concat -->
    <mxCell id="catnode" value="concat([h_t, h_v], dim=−1)&#xa;[B, 256+256] = [B, 512]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;strokeWidth=2;fontSize=9;fontStyle=1;" vertex="1" parent="1">
