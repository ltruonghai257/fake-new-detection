    <mxCell id="residlbl" value="★  Text Residual Connection  (KEY DIFFERENCE vs Proposal A)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=9;fontStyle=1;fontColor=#C2410C;" vertex="1" parent="1">
      <mxGeometry x="348" y="692" width="516" height="18" as="geometry"/>
