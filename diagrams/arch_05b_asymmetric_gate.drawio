    <!-- AsymmetricGate -->
    <mxCell id="gate" value="AsymmetricGate&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;gate: Linear(512 → 256)&#xa;g = sigmoid(gate([h_t; h_v]))                   [B, 256]&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;fused = g ⊙ h_t  +  (1 − g) ⊙ h_v             [B, 256]&#xa;(text is asymmetrically richer: 768→256 vs 64→256 original dims)&#xa;gate logged per epoch for interpretability (gate &gt; 0.5 = text wins)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCA5A5;strokeColor=#DC2626;strokeWidth=2;fontSize=8.5;align=left;" vertex="1" parent="1">
      <mxGeometry x="340" y="536" width="530" height="136" as="geometry"/>
