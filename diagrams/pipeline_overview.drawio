    <mxCell id="p05bcache" value="Article Cache Builder&#xa;mean-pool n pairs → [N_art, 64]&#xa;(uniform average, no padding needed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="1004" y="822" width="420" height="46" as="geometry"/>
    </mxCell>
    <mxCell id="p05bmodel" value="AsymmetricGatedFusionHead&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;TextProjector:  Linear[768→256]+LayerNorm+ReLU&#xa;ImageProjector: Linear[64→256]+LayerNorm+ReLU&#xa;─────────────────────────────────────────&#xa;AsymmetricGate:&#xa;  g = sigmoid(Linear[512→256])&#xa;  fused = g·h_t + (1-g)·h_v   [B, 256]&#xa;─────────────────────────────────────────&#xa;Text Residual (preserves NEI signal):&#xa;  output = fused + LayerNorm(h_t)  [B, 256]&#xa;─────────────────────────────────────────&#xa;Dropout(0.3) + Linear[256→3]&#xa;─────────────────────────────────────────&#xa;Inspection: gate mean per epoch logged&#xa;(gate&gt;0.5 → text wins, as expected for NEI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FECACA;strokeColor=#DC2626;fontSize=8.5;align=left;" vertex="1" parent="1">
      <mxGeometry x="1004" y="876" width="420" height="220" as="geometry"/>
    </mxCell>

