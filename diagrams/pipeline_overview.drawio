      <mxGeometry x="570" y="796" width="390" height="326" as="geometry"/>
    </mxCell>
    <mxCell id="p05atitle" value="Proposal A  —  05a_mil_attention_fusion.ipynb" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10;fontStyle=1;fontColor=#9333EA;" vertex="1" parent="1">
      <mxGeometry x="574" y="798" width="382" height="20" as="geometry"/>
    </mxCell>

    <mxCell id="p05acache" value="MIL Cache Builder&#xa;group pairs by article_id&#xa;pad to max_pairs=8  [N, 8, 64]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9D5FF;strokeColor=#9333EA;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="584" y="822" width="360" height="46" as="geometry"/>
    </mxCell>
    <mxCell id="p05amodel" value="MILAttentionFusionHead&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;TextProjector:  Linear[768→256]+LayerNorm+ReLU&#xa;ImageProjector: Linear[64→256]+LayerNorm+ReLU&#xa;(applied to each of 8 pairs independently)&#xa;───────────────────────────────────────&#xa;MILAttentionPooling (tanh-dot):&#xa;  score_i = v·tanh(W·img_i)  [8 scores]&#xa;  α = masked_softmax(scores)  [ignore pads]&#xa;  img_agg = Σ αᵢ · imgᵢ  →  [B, 256]&#xa;───────────────────────────────────────&#xa;AsymmetricGate:&#xa;  g = sigmoid(Linear[512→256])&#xa;  fused = g·h_t + (1-g)·h_img  [B, 256]&#xa;Dropout(0.3) + Linear[256→3]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9D5FF;strokeColor=#9333EA;fontSize=8.5;align=left;" vertex="1" parent="1">
      <mxGeometry x="584" y="876" width="360" height="220" as="geometry"/>
