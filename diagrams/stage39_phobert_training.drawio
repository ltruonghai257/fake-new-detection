<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Stage 3.9: PhoBERT Training">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="Stage 3.9: PhoBERT Text Classifier Training on ViFactCheck"
          style="text;html=1;align=center;fontStyle=1;fontSize=16;fillColor=none;strokeColor=none;"
          vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="950" height="40" as="geometry" />
        </mxCell>

        <!-- Step 1: Data Source -->
        <mxCell id="3" value="&lt;b&gt;HuggingFace Dataset&lt;/b&gt; — tranthaihoa/vifactcheck&#xa;Statement (claim text)  +  Evidence (retrieved sentences)  +  Labels (0/1/2)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="250" y="80" width="560" height="70" as="geometry" />
        </mxCell>

        <!-- Step 2: Label Mapping -->
        <mxCell id="4" value="&lt;b&gt;Label Strategy: nei_as_real&lt;/b&gt;&#xa;Supported (0) → Real (0)   |   NEI (2) → Real (0)   |   Refuted (1) → Fake (1)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="210" width="660" height="60" as="geometry" />
        </mxCell>

        <!-- Step 3: Tokenizer -->
        <mxCell id="5" value="&lt;b&gt;PhoBERT Tokenizer&lt;/b&gt;&#xa;Text pair: (Statement, Evidence)   |   truncation=only_second, padding=max_length&#xa;Outputs: input_ids [B, seq_len],  attention_mask [B, seq_len]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="200" y="330" width="660" height="75" as="geometry" />
        </mxCell>

        <!-- Step 4: Model container -->
        <mxCell id="6" value="PhoBERTClassifier  (vinai/phobert-base-v2)"
          style="swimlane;startSize=35;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="120" y="465" width="820" height="155" as="geometry" />
        </mxCell>

        <mxCell id="7" value="&lt;b&gt;AutoModel Backbone&lt;/b&gt;&#xa;RoBERTa-based, 12 layers&#xa;last_hidden_state[:, 0, :] → [B, 768]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="6">
          <mxGeometry x="30" y="45" width="340" height="85" as="geometry" />
        </mxCell>

        <mxCell id="8" value="&lt;b&gt;Classification Head&lt;/b&gt;&#xa;Dropout (p=0.3)&#xa;Linear (768 → 2)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="6">
          <mxGeometry x="450" y="45" width="340" height="85" as="geometry" />
        </mxCell>

        <mxCell id="9" value="CLS token [B, 768]"
          style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;"
          edge="1" parent="6" source="7" target="8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 5: Loss -->
        <mxCell id="10" value="&lt;b&gt;Cross-Entropy Loss&lt;/b&gt;"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;"
          vertex="1" parent="1">
          <mxGeometry x="380" y="680" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- Step 6: Optimizer + Scheduler -->
        <mxCell id="11" value="&lt;b&gt;AdamW Optimizer&lt;/b&gt;  (lr=5e-6, weight_decay)&#xa;LR Scheduler: ReduceLROnPlateau&#xa;EarlyStopping: patience=5, max_epochs=15"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="230" y="820" width="600" height="75" as="geometry" />
        </mxCell>

        <!-- Step 7: Outputs -->
        <mxCell id="12" value="Stage 3.9 Outputs"
          style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="955" width="940" height="115" as="geometry" />
        </mxCell>

        <mxCell id="13" value="&lt;b&gt;best_model.pth&lt;/b&gt;&#xa;freeze_for_stage4=True&#xa;checkpoints_vifactcheck/&lt;run&gt;/"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
          vertex="1" parent="12">
          <mxGeometry x="15" y="38" width="280" height="65" as="geometry" />
        </mxCell>

        <mxCell id="14" value="&lt;b&gt;tokenizer/&lt;/b&gt;&#xa;checkpoint_manifest.json&#xa;phobert_feature_dim=768"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
          vertex="1" parent="12">
          <mxGeometry x="330" y="38" width="280" height="65" as="geometry" />
        </mxCell>

        <mxCell id="15" value="&lt;b&gt;stage39_{split}.h5&lt;/b&gt;&#xa;CLS features [N, 768]&#xa;→ Stage 4 phobert_gated input"
          style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;"
          vertex="1" parent="12">
          <mxGeometry x="645" y="25" width="280" height="80" as="geometry" />
        </mxCell>

        <!-- Flow edges -->
        <mxCell id="16" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="3" target="4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="17" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="4" target="5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="18" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="5" target="6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="19" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="6" target="10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="20" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="10" target="11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="21" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="11" target="12">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
