  <diagram name="Stage 3: COOLANT Training">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="2" value="Stage 3: COOLANT Multimodal Alignment Training"
