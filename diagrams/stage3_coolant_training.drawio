          vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="280" height="90" as="geometry" />
        </mxCell>

        <!-- Input: Image features -->
        <mxCell id="4" value="&lt;b&gt;Image Features&lt;/b&gt;&#xa;coolant_{split}.h5&#xa;image_features [N, 2048]&#xa;(ResNet50-encoded images)"
