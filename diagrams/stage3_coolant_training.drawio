          vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="280" height="90" as="geometry" />
        </mxCell>

        <!-- Phase 2 HDF5 label -->
        <mxCell id="5" value="Phase 2 HDF5 Features"
          style="text;html=1;align=center;fontStyle=2;fontSize=12;fillColor=none;strokeColor=none;"
          vertex="1" parent="1">
          <mxGeometry x="390" y="105" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- ResNetCOOLANT container -->
        <mxCell id="6" value="ResNetCOOLANT.from_config()  with Dimension Patches"
          style="swimlane;startSize=35;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="230" width="900" height="140" as="geometry" />
        </mxCell>

        <mxCell id="7" value="&lt;b&gt;patch_encoding&lt;/b&gt;&#xa;shared_image: Linear(2048 → 64)&#xa;Adapts ResNet50 2048-dim → 64-dim"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="6">
          <mxGeometry x="20" y="50" width="270" height="70" as="geometry" />
        </mxCell>

        <mxCell id="8" value="&lt;b&gt;patch_clip_projection&lt;/b&gt;&#xa;CLIP text proj: Linear(768 → 64)&#xa;CLIP img proj: Linear(64 → 64)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="6">
          <mxGeometry x="315" y="50" width="270" height="70" as="geometry" />
        </mxCell>

        <mxCell id="9" value="&lt;b&gt;patch_cnn_with_dropout&lt;/b&gt;&#xa;FastCNN 1D conv layers&#xa;Caption pooling: [N, 128, 768] → [N, 768]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="6">
          <mxGeometry x="610" y="50" width="270" height="70" as="geometry" />
        </mxCell>

        <!-- 3 Modules row -->
        <mxCell id="10" value="&lt;b&gt;Similarity Module&lt;/b&gt;&#xa;Cosine sim: text ↔ image&#xa;text_aligned [B, 64]&#xa;image_aligned [B, 64]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="435" width="260" height="95" as="geometry" />
        </mxCell>

        <mxCell id="11" value="&lt;b&gt;CLIP Module&lt;/b&gt;&#xa;Contrastive alignment&#xa;text_aligned_clip [B, 64]&#xa;image_aligned_clip [B, 64]"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="400" y="435" width="260" height="95" as="geometry" />
        </mxCell>

        <mxCell id="12" value="&lt;b&gt;Detection Module&lt;/b&gt;&#xa;Fake news binary detection&#xa;detection_logits [B, 2]&#xa;attention_weights"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="720" y="435" width="260" height="95" as="geometry" />
        </mxCell>

        <!-- Losses row -->
        <mxCell id="13" value="&lt;b&gt;Cosine Embedding Loss&lt;/b&gt;&#xa;Matched vs. Unmatched pairs&#xa;(similarity alignment)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="595" width="260" height="75" as="geometry" />
        </mxCell>

        <mxCell id="14" value="&lt;b&gt;CLIP Contrastive Loss&lt;/b&gt;&#xa;Cross-modal alignment&#xa;compute_clip_loss(ta, ia)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="400" y="595" width="260" height="75" as="geometry" />
        </mxCell>

        <mxCell id="15" value="&lt;b&gt;Detection BCE Loss&lt;/b&gt;&#xa;Binary cross-entropy&#xa;on detection logits"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="720" y="595" width="260" height="75" as="geometry" />
        </mxCell>

        <!-- Combined loss -->
        <mxCell id="16" value="&lt;b&gt;Combined Loss&lt;/b&gt;&#xa;L = λ₁·L_cos + λ₂·L_clip + λ₃·L_det"
          style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="355" y="730" width="350" height="85" as="geometry" />
        </mxCell>

        <!-- Optimizer -->
        <mxCell id="17" value="&lt;b&gt;AdamW Optimizer&lt;/b&gt;  +  LR Scheduler&#xa;Backward pass → gradient update on all COOLANT modules"
