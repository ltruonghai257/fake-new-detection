          vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="960" height="40" as="geometry" />
        </mxCell>

        <!-- Input: Caption features -->
        <mxCell id="3" value="&lt;b&gt;Caption Features&lt;/b&gt;&#xa;coolant_{split}.h5&#xa;caption_features [N, 128, 768]&#xa;(PhoBERT-encoded captions)"
