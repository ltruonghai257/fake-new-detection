# Copy this file to .env and fill in the values.
# .env is git-ignored so secrets are never committed.

# Root directory for all large data files (processed_data/, training/,
# data/json, data/jpg, mlruns/).  Leave empty to keep data inside the repo.
# Example external drive: DATA_ROOT=/Volumes/MyDrive/fake-news-data
DATA_ROOT=

# Path to your Google service-account JSON key file (recommended).
# Share the target Drive folder with the service account email first.
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
