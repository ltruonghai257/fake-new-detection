# Google Colab environment — copy to .env before running notebooks.
# On Colab, mount Google Drive first:
#   from google.colab import drive
#   drive.mount('/content/drive')

# Local path on Colab (Drive mounted at /content/drive)
DATA_ROOT=/content/drive/MyDrive/Thesis_Final/fake-news-data-for-thesis

# Platform identifier (used by env_utils.py)
PLATFORM=colab

# Not needed on Colab (Drive is mounted locally)
# GOOGLE_APPLICATION_CREDENTIALS=
